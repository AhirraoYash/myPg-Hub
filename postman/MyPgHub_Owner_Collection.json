{
	"info": {
		"_postman_id": "owner-mypghub-2026",
		"name": "MyPg Hub — Owner",
		"description": "Complete Postman collection for the **Owner** role of MyPg Hub.\n\n## Auth Flow\n1. Call **Login** with the Owner's phone & PIN.\n2. Copy the `token` from the response.\n3. The token is auto-set in the collection variable `{{token}}`.\n\n## Variable Setup\n- `baseUrl` → `http://localhost:5000`\n- `token`   → Set automatically after login\n\nAll protected routes use `Bearer {{token}}` in the Authorization header.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "property_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "tenant_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "room_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "bed_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "invoice_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "payment_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "notice_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "complaint_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "manager_id",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "🔐 Auth",
			"item": [
				{
					"name": "Register Owner & Property",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.token) {",
									"    pm.collectionVariables.set('token', res.data.token);",
									"    pm.collectionVariables.set('property_id', res.data.property.id);",
									"    console.log('✅ Token & property_id saved from register');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\",\n    \"pin\": \"1234\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"pg_name\": \"My PG Hub Premium\",\n    \"address\": \"Main Street, Bangalore\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Quickly register a new owner logic & property. Auto-saves token & property_id."
					}
				},
				{
					"name": "Login (Owner)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.token) {",
									"    pm.collectionVariables.set('token', res.data.token);",
									"    pm.collectionVariables.set('property_id', res.data.user.property_id);",
									"    console.log('✅ Token & property_id saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9999999999\",\n    \"pin\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login with Owner phone & PIN. Auto-saves token & property_id to collection variables."
					}
				},
